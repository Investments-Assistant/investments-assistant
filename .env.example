# ══════════════════════════════════════════════════════════════════════════════
# Investment Assistant – Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=production          # development | production
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Security – IP Whitelist ────────────────────────────────────────────────────
# Comma-separated list of allowed CIDRs/IPs (applied in Nginx AND in-app).
# Example: your WireGuard VPN subnet + your static home IP.
ALLOWED_IPS=10.8.0.0/24,203.0.113.42

# ── LLM Backend (local, in-process — no external APIs) ───────────────────────
# Models run entirely on your hardware.  No data leaves your network.
#
#   llama_cpp      GGUF quantised models via llama-cpp-python
#                  CPU-optimised (ARM NEON on Pi 5) — RECOMMENDED for Pi 5
#
#   transformers   HuggingFace safetensors models via transformers + torch
#                  Better on GPU; noticeably slower on CPU-only hardware
LLM_BACKEND=llama_cpp

# ── llama_cpp settings ────────────────────────────────────────────────────────
# Absolute path to the GGUF file.  Download with:
#   python scripts/download_model.py --list     # see available presets
#   python scripts/download_model.py qwen2.5-7b # download one
#
# Tested on Pi 5 (8 GB RAM):
#   qwen2.5-7b-instruct-q4_k_m.gguf   ~4.7 GB  ← best quality/speed trade-off
#   llama-3.2-3b-instruct-q8_0.gguf   ~3.4 GB  ← faster, lower RAM
#   mistral-7b-instruct-q4_k_m.gguf   ~4.4 GB  ← solid all-rounder
LLM_MODEL_PATH=/app/models/qwen2.5-7b-instruct-q4_k_m.gguf
LLM_CONTEXT_SIZE=4096
LLM_N_GPU_LAYERS=0                  # 0 = CPU only (Pi 5 has no GPU)

# ── transformers settings ─────────────────────────────────────────────────────
# HuggingFace model ID (downloaded on first run) or path to a local directory.
# Examples: Qwen/Qwen2.5-7B-Instruct | meta-llama/Llama-3.1-8B-Instruct
LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
LLM_DEVICE=cpu                      # cpu | cuda | mps

# ── Shared inference settings ─────────────────────────────────────────────────
AGENT_MAX_TOKENS=2048               # lower = faster on Pi 5
AGENT_TEMPERATURE=0.1

# ── Trading Mode ──────────────────────────────────────────────────────────────
# recommend  → agent proposes trades, you confirm via chat
# auto       → agent executes trades automatically (within safety limits)
TRADING_MODE=recommend

# Auto-mode safety limits (only used when TRADING_MODE=auto)
AUTO_MAX_TRADE_USD=500          # Max USD value per single trade
AUTO_DAILY_LOSS_LIMIT_USD=1000  # Stop auto-trading if daily loss exceeds this
AUTO_ALLOWED_SYMBOLS=           # Comma-separated; empty = all symbols allowed

# ── Database – PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=investment_assistant
POSTGRES_USER=ia_user
POSTGRES_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Alpaca Markets ────────────────────────────────────────────────────────────
# Get keys at: https://app.alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true               # true = paper trading, false = live

# ── Interactive Brokers ───────────────────────────────────────────────────────
# Requires IB Gateway running separately (see docs/ibkr-gateway.md)
IBKR_HOST=host.docker.internal  # or 127.0.0.1 if running on host
IBKR_PORT=4002                  # 4001 = live, 4002 = paper
IBKR_CLIENT_ID=1
IBKR_ENABLED=false              # set true once IB Gateway is configured

# ── Coinbase Advanced Trade ───────────────────────────────────────────────────
# Get keys at: https://www.coinbase.com/settings/api
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ── Binance ───────────────────────────────────────────────────────────────────
# Get keys at: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true            # true = testnet, false = live

# ── News API ──────────────────────────────────────────────────────────────────
# Get a free key at: https://newsapi.org/
NEWSAPI_KEY=

# ── Scheduler ────────────────────────────────────────────────────────────────
# How often to refresh market data (in minutes, market hours only)
MARKET_DATA_REFRESH_MINUTES=5
# Day of week for weekly report (0=Monday … 6=Sunday) and time (UTC)
WEEKLY_REPORT_DAY=6             # Sunday
WEEKLY_REPORT_HOUR=18
WEEKLY_REPORT_MINUTE=0

# ── Reports ───────────────────────────────────────────────────────────────────
REPORTS_DIR=/app/reports        # inside the container

# ── Pi-hole ───────────────────────────────────────────────────────────────────
PIHOLE_PASSWORD=change_me_pihole_password
TZ=Europe/Lisbon                # your timezone (used by Pi-hole)
